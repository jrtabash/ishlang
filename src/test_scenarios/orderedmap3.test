__CODE__
(var ot (orderedmap (array "one" 1) (array "two" 2) (array "three" 3) (array "two2" 2)))

(var keys (omkeys ot))
(var vals (omvals ot))
(var items (omitems ot))

(println (arrlen keys))
(println (arrlen vals))
(println (arrlen items))

(println (== (get keys 0) "one"))
(println (== (get keys 1) "three"))
(println (== (get keys 2) "two"))
(println (== (get keys 3) "two2"))

(println (== (get vals 0) 1))
(println (== (get vals 1) 3))
(println (== (get vals 2) 2))
(println (== (get vals 3) 2))

(println (== (get items 0) (pair "one" 1)))
(println (== (get items 1) (pair "three" 3)))
(println (== (get items 2) (pair "two" 2)))
(println (== (get items 3) (pair "two2" 2)))

__EXPECT__
4
4
4
true
true
true
true
true
true
true
true
