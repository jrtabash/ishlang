__CODE__
(defun sum_check (rng)
    (var s (sum rng))
    (println s)
    (println (== s (sum (expand rng)))))

(sum_check (range 0))
(sum_check (range 1))
(sum_check (range 2))
(sum_check (range 10))
(sum_check (range 0 -1 -1))

(sum_check (range 1 101))
(sum_check (range 1 101 2))
(sum_check (range 1 101 3))

(sum_check (range -10 12))
(sum_check (range -10 12 2))
(sum_check (range -10 12 3))

(sum_check (range 11 -8 -1))
(sum_check (range 11 -8 -2))
(sum_check (range 11 -8 -3))

